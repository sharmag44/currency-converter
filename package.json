{
  "name": "currency-converter",
  "version": "1.0.0",
  "description": "A lightweight npm package to retrieve latest currency conversion rates using Google scraping and alternative APIs",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node -e \"require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'}))\"",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "npm run build"
  },
  "keywords": [
    "currency",
    "conversion",
    "exchange",
    "rate",
    "google",
    "scraper",
    "finance"
  ],
  "author": "sharmag44",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.1.3",
    "cheerio": "1.0.0-rc.10",
    "dotenv": "^16.4.5",
    "puppeteer": "^19.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.1.2"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sharmag44/currency-converter.git"
  },
  "bugs": {
    "url": "https://github.com/sharmag44/currency-converter/issues"
  },
  "homepage": "https://github.com/sharmag44/currency-converter#readme"
}